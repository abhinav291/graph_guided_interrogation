GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Cheapest current-gen: Haiku 4.5 (~$1/M in, $5/M out). Alternatives: claude-sonnet-4-6, claude-3-5-haiku-latest
ANTHROPIC_MODEL=claude-haiku-4-5
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
# Production: add your Netlify URL(s), comma-separated:
# CORS_ORIGINS=https://your-app.netlify.app,https://main--your-app.netlify.app
CHUNK_MAX_CHARS=1000
# Optional: override session JSON storage (e.g. Render persistent disk mount)
# SESSIONS_DIR=/var/data/sessions
